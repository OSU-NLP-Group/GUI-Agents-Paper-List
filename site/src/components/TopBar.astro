---
import ThemeToggle from './ThemeToggle.astro';
import { REPO_URL, SITE_TITLE } from '../lib/site';
const { starCount } = Astro.props as { starCount: number | null };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function fmt(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(n >= 10000 ? 0 : 1).replace(/\.0$/, '') + 'k';
  return String(n);
}

const navItems = [
  { href: `${base}/papers`, label: 'Browse' },
  { href: `${base}/stats`, label: 'Stats' },
  { href: `${base}/adjacent`, label: 'Adjacent' },
  { href: `${base}/about`, label: 'About' },
];
const currentPath = Astro.url.pathname.replace(/\/$/, '');
---
<header class="sticky top-0 z-40 backdrop-blur-md bg-paper-100/80 dark:bg-nightbg/80 border-b border-paper-300/60 dark:border-ink-600/60">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 h-14 flex items-center gap-3">
    <a href={`${base}/`} class="flex items-center gap-2 group">
      <span aria-hidden="true" class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-accent text-paper-50 dark:bg-accent-dark dark:text-ink-900 font-bold text-sm leading-none">G</span>
      <span class="font-semibold tracking-tight text-ink-700 dark:text-ink-50 group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">{SITE_TITLE}</span>
    </a>

    <nav class="hidden md:flex items-center gap-1 ml-4">
      {navItems.map((item) => {
        const active = currentPath === item.href.replace(/\/$/, '') ||
          (item.href !== `${base}/` && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class={`px-3 py-1.5 rounded-md text-sm transition-colors ${
              active
                ? 'text-accent dark:text-accent-dark font-medium'
                : 'text-ink-500 dark:text-ink-200 hover:text-ink-700 dark:hover:text-ink-50 hover:bg-paper-200/60 dark:hover:bg-ink-700/40'
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="flex-1"></div>

    <a
      href={REPO_URL}
      target="_blank"
      rel="noopener"
      class="hidden sm:inline-flex items-center gap-2 px-3 py-1.5 rounded-md text-sm text-ink-600 dark:text-ink-100 border border-paper-300/80 dark:border-ink-600/60 hover:bg-paper-200/60 dark:hover:bg-ink-700/40 transition-colors"
      aria-label="View on GitHub"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 .5a11.5 11.5 0 0 0-3.63 22.41c.58.1.79-.25.79-.56v-2.04c-3.2.7-3.88-1.36-3.88-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55A11.5 11.5 0 0 0 12 .5z"/></svg>
      <span>GitHub</span>
    </a>

    <a
      href={REPO_URL}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm font-medium bg-accent text-paper-50 dark:bg-accent-dark dark:text-ink-900 hover:opacity-90 transition-opacity"
      aria-label="Open repo to star on GitHub"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M12 2l2.96 6.55 7.04.74-5.27 4.84 1.55 6.97L12 17.77 5.72 21.1l1.55-6.97L2 9.29l7.04-.74L12 2z"/></svg>
      <span>Star{starCount != null ? ` · ${fmt(starCount)}` : ''}</span>
    </a>

    <ThemeToggle />
  </div>
</header>
