---
import Base from '../../layouts/Base.astro';
import PaperBrowser from '../../islands/PaperBrowser';
import { loadAllPapers } from '../../lib/parsePapers';
import { REPO_RAW_BLOB } from '../../lib/site';

const { canonical, adjacent } = loadAllPapers();
const all = [...canonical, ...adjacent];
const lite = all.map((p) => ({
  slug: p.slug, title: p.title, link: p.link,
  authors: p.authors, institutions: p.institutions,
  date: p.date, dateISO: p.dateISO, year: p.year, month: p.month,
  publisher: p.publisher, envs: p.envs, keywords: p.keywords,
  tldr: p.tldr, arxivId: p.arxivId, source: p.source, sourceLine: p.sourceLine,
  bibtex: p.bibtex, bibtexConfirmed: p.bibtexConfirmed, sources: p.sources,
}));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base
  title="Browse all GUI agent papers"
  description={`Search and filter ${canonical.length}+ GUI agent papers by environment (web, mobile, desktop, general GUI), keyword, author, institution, year, and venue. Includes computer-use agents, GUI grounding, benchmarks, and datasets.`}
>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-8 reveal-stagger">
    <div class="mb-8 flex flex-wrap items-end gap-4 justify-between">
      <div>
        <p class="heading-eyebrow">Browse</p>
        <h1 class="display-lg mt-2 text-ink-700 dark:text-ink-50">All papers</h1>
        <p class="text-ink-500 dark:text-ink-200 mt-2 max-w-2xl">
          <strong class="tabular-nums text-ink-700 dark:text-ink-50">{canonical.length}</strong>
          canonical papers — search across titles, authors, institutions, TLDRs, and keywords. Click any chip to drill in.
        </p>
      </div>
    </div>

    <PaperBrowser client:only="solid-js" papers={lite} basePath={base} repoBlobUrl={REPO_RAW_BLOB} />
    <noscript>
      <div class="surface rounded-lg p-6 mt-4 text-sm text-ink-600 dark:text-ink-100">
        The interactive browser needs JavaScript. You can still view the
        <a class="link" href="https://github.com/OSU-NLP-Group/GUI-Agents-Paper-List/blob/main/papers.yaml">full structured list on GitHub</a>.
      </div>
    </noscript>
  </section>
</Base>
