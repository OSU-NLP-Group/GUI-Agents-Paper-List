---
import Base from '../layouts/Base.astro';
import { loadAllPapers } from '../lib/parsePapers';
import { ENV_ORDER, ENV_EMOJI, REPO_URL } from '../lib/site';
import { getStarCount } from '../lib/star';

const { canonical } = loadAllPapers();
const envCount: Record<string, number> = {};
for (const p of canonical) for (const e of p.envs) envCount[e] = (envCount[e] ?? 0) + 1;

const lastYear = new Date().getFullYear();
const thisYear = canonical.filter((p) => p.year === lastYear).length;
const stars = await getStarCount();

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = (Astro.site ?? new URL('https://osu-nlp-group.github.io')).toString().replace(/\/$/, '') + base;

const description = `A curated, searchable list of ${canonical.length}+ research papers on GUI agents — including web agents, mobile agents, desktop computer-use agents, GUI grounding, planning, safety, benchmarks, datasets, and reinforcement learning. Maintained openly by OSU NLP.`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'GUI Agents Papers',
    alternateName: 'GUI Agents Paper List',
    url: siteUrl + '/',
    description,
    inLanguage: 'en',
    publisher: {
      '@type': 'Organization',
      name: 'OSU NLP Group',
      url: 'https://github.com/OSU-NLP-Group',
    },
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${siteUrl}/papers/?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'DataCatalog',
    name: 'GUI Agents Paper List',
    description,
    url: siteUrl + '/',
    keywords: 'GUI agent, web agent, mobile agent, desktop agent, computer-use agent, GUI grounding, GUI benchmark',
    creator: { '@type': 'Organization', name: 'OSU NLP Group' },
  },
];
---
<Base
  title="A curated list of GUI agent research papers"
  description={description}
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section class="mx-auto max-w-5xl px-4 sm:px-6 pt-20 sm:pt-28 pb-12 reveal-stagger">
    <p class="heading-eyebrow">A curated paper list</p>
    <h1 class="display-xl mt-4 text-ink-700 dark:text-ink-50 max-w-4xl">
      Research on <span class="text-accent dark:text-accent-dark">GUI agents</span>, kept up to date and easy to search.
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-ink-500 dark:text-ink-200 leading-relaxed">
      <strong class="tabular-nums text-ink-700 dark:text-ink-50">{canonical.length}</strong> papers spanning models, frameworks, benchmarks, datasets, GUI grounding, planning, safety, and reinforcement learning.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a href={`${base}/papers`} class="btn-primary text-base px-5 py-2.5">Browse all papers →</a>
      <a href={`${base}/stats`} class="btn-ghost border border-paper-300/80 dark:border-ink-600/60 px-4 py-2.5 text-base">View stats</a>
    </div>
  </section>

  {/* Browse-by-env — primary navigation, with display numerals */}
  <section class="mx-auto max-w-5xl px-4 sm:px-6 pb-12 reveal" style="animation-delay:560ms">
    <div class="flex items-center justify-between mb-5">
      <h2 class="heading-eyebrow">Browse by environment</h2>
      <div class="flex-1 mx-4 rule"></div>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
      {ENV_ORDER.map((env) => (
        <a
          href={`${base}/papers?env=${encodeURIComponent(env)}`}
          class="card p-5 group hover:border-accent/60 dark:hover:border-accent-dark/60 flex items-baseline gap-4"
        >
          <span aria-hidden="true" class="text-2xl shrink-0 self-center">{ENV_EMOJI[env]}</span>
          <div class="min-w-0 flex-1">
            <div class="font-semibold text-ink-700 dark:text-ink-50">{env}</div>
            <div class="text-sm text-ink-400 dark:text-ink-300 mt-0.5 tabular-nums">{envCount[env] ?? 0} papers</div>
          </div>
          <span aria-hidden="true" class="text-ink-300 dark:text-ink-400 group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">→</span>
        </a>
      ))}
    </div>
  </section>

  {/* Star CTA — single placement, not duplicated with top bar */}
  <section class="mx-auto max-w-5xl px-4 sm:px-6 pb-12">
    <div class="surface rounded-lg px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="shrink-0 w-10 h-10 rounded-md bg-accent/10 dark:bg-accent-dark/15 flex items-center justify-center text-accent dark:text-accent-dark">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2l2.96 6.55 7.04.74-5.27 4.84 1.55 6.97L12 17.77 5.72 21.1l1.55-6.97L2 9.29l7.04-.74L12 2z"/></svg>
      </div>
      <div class="flex-1 text-sm text-ink-600 dark:text-ink-100 leading-relaxed">
        Maintained openly on GitHub by <a class="link" href="https://github.com/OSU-NLP-Group" target="_blank" rel="noopener">OSU NLP</a>. If this list helps your work, <strong>star the repo</strong> so others can find it too.
      </div>
      <a href={`${REPO_URL}/stargazers`} target="_blank" rel="noopener" class="btn-primary shrink-0">
        {stars != null ? `Star · ${stars >= 1000 ? (stars/1000).toFixed(1).replace(/\.0$/, '') + 'k' : stars}` : 'Star on GitHub'}
      </a>
    </div>
  </section>

  {/* Year-to-date strip — single line, no duplicate UI */}
  <section class="mx-auto max-w-5xl px-4 sm:px-6 pb-20">
    <p class="text-sm text-ink-400 dark:text-ink-300 text-center">
      <strong class="text-ink-600 dark:text-ink-100">{thisYear}</strong> papers added so far in {lastYear} ·
      <a class="link" href={`${base}/stats`}>see breakdown by quarter →</a>
    </p>
  </section>
</Base>
