---
import Base from '../layouts/Base.astro';
import PaperCard from '../components/PaperCard.astro';
import { loadAllPapers } from '../lib/parsePapers';
import { ENV_ORDER, ENV_EMOJI, REPO_URL } from '../lib/site';
import { getStarCount } from '../lib/star';

const { canonical } = loadAllPapers();
const recent = canonical.slice(0, 6);

const envCount: Record<string, number> = {};
for (const p of canonical) for (const e of p.envs) envCount[e] = (envCount[e] ?? 0) + 1;

const kwCount: Record<string, number> = {};
for (const p of canonical) for (const k of p.keywords) kwCount[k] = (kwCount[k] ?? 0) + 1;
const topKw = Object.entries(kwCount).sort((a, b) => b[1] - a[1]).slice(0, 18);

const yearCount: Record<number, number> = {};
for (const p of canonical) if (p.year > 0) yearCount[p.year] = (yearCount[p.year] ?? 0) + 1;
const lastYear = new Date().getFullYear();
const thisYearCount = yearCount[lastYear] ?? 0;

const stars = await getStarCount();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base>
  {/* Hero */}
  <section class="relative">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 pt-14 sm:pt-20 pb-10">
      <p class="heading-eyebrow">A curated paper list</p>
      <h1 class="mt-3 text-4xl sm:text-5xl font-semibold tracking-tight text-ink-700 dark:text-ink-50 leading-[1.05] max-w-3xl">
        Research on <span class="text-accent dark:text-accent-dark">GUI agents</span>, kept up to date and easy to search.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-ink-500 dark:text-ink-200 leading-relaxed">
        {canonical.length} papers on web, mobile, desktop, and general-GUI agents — including frameworks, benchmarks, datasets, grounding, planning, safety, and reinforcement learning.
        Maintained openly on GitHub by <a class="link" href="https://github.com/OSU-NLP-Group" target="_blank" rel="noopener">OSU NLP</a>.
      </p>

      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a href={`${base}/papers`} class="btn-primary text-base px-5 py-2.5">Browse papers →</a>
        <a href={REPO_URL} target="_blank" rel="noopener" class="btn-ghost border border-paper-300/80 dark:border-ink-600/60 px-4 py-2.5">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 .5a11.5 11.5 0 0 0-3.63 22.41c.58.1.79-.25.79-.56v-2.04c-3.2.7-3.88-1.36-3.88-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.95.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.55A11.5 11.5 0 0 0 12 .5z"/></svg>
          View on GitHub
        </a>
      </div>

      {/* Star CTA — honest, not nagging */}
      <div class="mt-10 surface rounded-lg px-5 py-4 flex items-center gap-4 max-w-3xl">
        <div class="shrink-0 w-10 h-10 rounded-md bg-accent/10 dark:bg-accent-dark/15 flex items-center justify-center text-accent dark:text-accent-dark">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2l2.96 6.55 7.04.74-5.27 4.84 1.55 6.97L12 17.77 5.72 21.1l1.55-6.97L2 9.29l7.04-.74L12 2z"/></svg>
        </div>
        <div class="flex-1 text-sm text-ink-600 dark:text-ink-100">
          <p>This list is maintained by researchers in the open. If it helps your work, <strong>star the repo</strong> so others can find it too.</p>
        </div>
        <a href={`${REPO_URL}/stargazers`} target="_blank" rel="noopener" class="btn-primary shrink-0">
          {stars != null ? `Star · ${stars >= 1000 ? (stars/1000).toFixed(1).replace(/\.0$/, '') + 'k' : stars}` : 'Star on GitHub'}
        </a>
      </div>
    </div>
  </section>

  {/* Quick stats strip */}
  <section class="border-y border-paper-300/60 dark:border-ink-600/60 bg-paper-50/40 dark:bg-nightbg-soft/40">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-6 grid grid-cols-2 md:grid-cols-5 gap-6 text-sm">
      <div>
        <div class="text-2xl font-semibold text-ink-700 dark:text-ink-50">{canonical.length}</div>
        <div class="text-ink-400 dark:text-ink-300">papers tracked</div>
      </div>
      {ENV_ORDER.map((env) => (
        <a href={`${base}/papers?env=${encodeURIComponent(env)}`} class="block hover:opacity-80 transition-opacity">
          <div class="text-2xl font-semibold text-ink-700 dark:text-ink-50">{envCount[env] ?? 0}</div>
          <div class="text-ink-400 dark:text-ink-300">
            <span aria-hidden="true">{ENV_EMOJI[env]}</span> {env}
          </div>
        </a>
      ))}
    </div>
  </section>

  {/* Browse by env (rich tiles) */}
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <h2 class="heading-eyebrow">Browse by environment</h2>
    <div class="mt-4 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {ENV_ORDER.map((env) => (
        <a href={`${base}/papers?env=${encodeURIComponent(env)}`} class="card p-5 group hover:border-accent/60 dark:hover:border-accent-dark/60">
          <div class="flex items-center gap-2.5 text-2xl">
            <span aria-hidden="true">{ENV_EMOJI[env]}</span>
            <span class="text-base font-semibold text-ink-700 dark:text-ink-50">{env}</span>
          </div>
          <div class="mt-3 text-sm text-ink-500 dark:text-ink-200">{envCount[env] ?? 0} papers</div>
          <div class="mt-3 text-xs text-accent dark:text-accent-dark opacity-0 group-hover:opacity-100 transition-opacity">Browse →</div>
        </a>
      ))}
    </div>
  </section>

  {/* Top keywords as chip cloud */}
  <section class="mx-auto max-w-6xl px-4 sm:px-6 pb-4">
    <h2 class="heading-eyebrow">Popular keywords</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {topKw.map(([kw, count]) => (
        <a href={`${base}/papers?key=${encodeURIComponent(kw)}`} class="chip">
          <span>{kw}</span>
          <span class="text-ink-400 dark:text-ink-300">· {count}</span>
        </a>
      ))}
    </div>
  </section>

  {/* Recent papers */}
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
    <div class="flex items-end justify-between mb-5">
      <h2 class="heading-eyebrow">Recent additions</h2>
      <a class="link text-sm" href={`${base}/papers`}>See all →</a>
    </div>
    <ul class="grid md:grid-cols-2 gap-4">
      {recent.map((p) => (
        <li><PaperCard paper={p} compact={true} /></li>
      ))}
    </ul>
  </section>

  {/* Year-in-review nudge */}
  <section class="mx-auto max-w-6xl px-4 sm:px-6 py-6">
    <div class="surface rounded-lg p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-1">
        <p class="heading-eyebrow">{lastYear} so far</p>
        <p class="mt-2 text-lg text-ink-700 dark:text-ink-50"><strong>{thisYearCount}</strong> new papers added this year.</p>
        <p class="text-sm text-ink-500 dark:text-ink-200 mt-1">See the breakdown by quarter and environment.</p>
      </div>
      <a href={`${base}/stats`} class="btn-primary">Open stats →</a>
    </div>
  </section>
</Base>
